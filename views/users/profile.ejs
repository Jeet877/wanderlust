<% layout('/layouts/boilerplate') %>

<div class="container mt-5">

  <h1 class="mb-4">My Profile</h1>

  <div class="card p-4 shadow-sm">

    <!-- Avatar -->
    <div class="text-center mb-3">
      <img 
        src="<%= user.avatar %>" 
        alt="Profile Picture" 
        style="width:120px; height:120px; border-radius:50%; object-fit:cover;"
      >
    </div>

    <!-- Basic Info -->
    <p><strong>Username:</strong> <%= user.username %></p>
    <p><strong>Email:</strong> <%= user.email %></p>

    <!-- Optional Fields -->
    <% if (user.fullName) { %>
      <p><strong>Full Name:</strong> <%= user.fullName %></p>
    <% } %>

    <% if (user.bio) { %>
      <p><strong>Bio:</strong> <%= user.bio %></p>
    <% } %>

    <% if (user.phone) { %>
      <p><strong>Phone:</strong> <%= user.phone %></p>
    <% } %>

    <% if (user.gender) { %>
      <p><strong>Gender:</strong> <%= user.gender %></p>
    <% } %>

    <% if (user.address) { %>
      <p><strong>Address:</strong> <%= user.address %></p>
    <% } %>

    <a href="/profile/edit" class="btn btn-primary mt-3">Edit Profile</a>

  </div>

</div>


<style>
/* Container styling */
.container {
  max-width: 600px;
}

/* Card Styling */
.card {
  background: linear-gradient(145deg, #ffffff, #f0f0f5);
  border-radius: 1rem;
  padding: 2rem 1.5rem;
  box-shadow: 0 10px 25px rgba(0,0,0,0.1);
  transition: transform 0.3s, box-shadow 0.3s, background 0.5s;
  position: relative;
  overflow: hidden;
}

/* Card gradient animation */
@keyframes gradientShift {
  0% { background-position: 0% 50%; }
  50% { background-position: 100% 50%; }
  100% { background-position: 0% 50%; }
}

.card {
  background: linear-gradient(145deg, #ffffff, #f0f0f5, #e0ffe0, #f0f0f5);
  background-size: 400% 400%;
  animation: gradientShift 15s ease infinite, floatCard 6s ease-in-out infinite;
}

/* Card hover lift */
.card:hover {
  transform: translateY(-7px);
  box-shadow: 0 18px 40px rgba(0,0,0,0.2);
}

/* Profile Image Styling */
/* Profile Image Styling */
.card img {
  width: 120px;
  height: 120px;
  border-radius: 50%;
  object-fit: cover;
  border: 4px solid #00b300;
  box-shadow: 0 5px 15px rgba(0,0,0,0.1);
  transition: transform 0.4s ease, box-shadow 0.4s ease, filter 0.4s ease;
  animation: pulseGrow 3s ease-in-out infinite, pulseGlow 3s ease-in-out infinite;
}

/* Hover effect (optional extra) */
.card img:hover {
  transform: scale(1.2) rotate(5deg);
  box-shadow: 0 0 25px 10px rgba(0,179,0,0.6);
  filter: brightness(1.1);
}

/* Pulsing grow animation */
@keyframes pulseGrow {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.15); } /* yahan scale adjust kar sakte ho */
}

/* Pulsing glow effect */
@keyframes pulseGlow {
  0%, 100% { box-shadow: 0 0 15px 4px rgba(0,179,0,0.3); }
  50% { box-shadow: 0 0 25px 8px rgba(0,179,0,0.6); }
}


/* Headings */
h1 {
  font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
  color: #333;
  text-align: center;
  position: relative;
}

h1::after {
  content: '';
  display: block;
  width: 80px;
  height: 3px;
  background-color: #00b300;
  margin: 8px auto 0 auto;
  border-radius: 2px;
}

/* Labels and Info */
.card p {
  font-family: 'Roboto', sans-serif;
  font-size: 0.95rem;
  color: #444;
  margin-bottom: 0.5rem;
  /* Removed hover color change */
  transition: transform 0.3s ease; /* optional slide effect */
}

.card:hover p {
  transform: translateX(2px); /* only slight move, no color change */
}

/* Button Styling */
.btn-primary {
  background-color: #00b300;
  border: none;
  border-radius: 0.5rem;
  padding: 0.5rem 1.2rem;
  font-weight: 500;
  transition: background-color 0.3s, transform 0.2s, box-shadow 0.3s;
  position: relative;
  overflow: hidden;
}

.btn-primary::after {
  content: '';
  position: absolute;
  top: 0;
  left: -75%;
  width: 50%;
  height: 100%;
  background: rgba(255,255,255,0.3);
  transform: skewX(-20deg);
  transition: left 0.5s ease;
}

.btn-primary:hover::after {
  left: 125%;
}

.btn-primary:hover {
  background-color: #00a300;
  transform: translateY(-2px);
  box-shadow: 0 5px 15px rgba(0,179,0,0.3);
}

/* Floating Animation for card */
@keyframes floatCard {
  0%, 100% { transform: translateY(0px); }
  50% { transform: translateY(-5px); }
}
</style>
