<% layout("/layouts/boilerplate") %>


<style>
  .navbar input[type="search"],
.navbar .btn.btn-danger {
  display: none !important;
  
}
</style>
<style>
  .navbar .search-inp,
  .navbar .search-btn{
    display: none !important;
  }
</style>



<style>
/* Airbnb-style light theme base */
body {
  background-color: #f7f7f7; /* soft off-white background */
  color: #333;               /* soft dark text for readability */
  font-family: 'Poppins', sans-serif;
  font-weight: 400;          /* normal text weight, not bold */
}

/* Center login section more elegantly */
.row {
  margin-top: 80px !important;
}

/* Heading Style */
h1 {
  color: #222;               /* slightly darker for headings */
  font-weight: 500;          /* medium weight for headings */
  text-align: center;
  margin-bottom: 25px;
  letter-spacing: 0.5px;
  transition: all 0.3s ease;
}

/* Form box soft Airbnb-style card */
.col-6.offset-3 {
  background: #ffffff;                     /* soft white card */
  padding: 40px 35px;
  border-radius: 15px;
  box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08); /* subtle shadow */
  transition: box-shadow 0.4s ease, transform 0.3s ease;
   

}

.col-6.offset-3:hover {
  box-shadow: 0 8px 25px rgba(0, 0, 0, 0.12);
  transform: translateY(-2px);
}

/* Input fields */
.form-control {
  background-color: #f1f1f1; /* light gray input */
  border: 1px solid #ddd;
  color: #333;               /* soft dark text */
  border-radius: 10px;
  padding: 10px 15px;
  transition: all 0.3s ease;
}

.form-control::placeholder {
  color: #aaa;               /* soft placeholder */
}

.form-control:focus {
  background-color: #fff;
  border-color: #00bfa5;     /* subtle mint accent */
  color: #222;               /* normal text on focus */
  box-shadow: 0 0 10px rgba(0, 191, 165, 0.3);
  outline: none;
}

/* Labels */
.form-label {
  font-weight: 500;
  margin-bottom: 5px;
  color: #555;
}

/* Login Button */
.btn-success {
  background: linear-gradient(135deg, #00bfa5, #00d1c1); /* soft mint gradient */
  border: none;
  border-radius: 10px;
  padding: 10px 25px;
  font-weight: 500; /* medium weight */
  width: 100%;
  transition: all 0.4s ease;
  box-shadow: 0 0 8px rgba(0, 191, 165, 0.2);
}

.btn-success:hover {
  background: linear-gradient(135deg, #00d1c1, #00ffc8);
  transform: translateY(-2px);
  box-shadow: 0 0 15px rgba(0, 191, 165, 0.4);
}

/* Smooth fade animation */
@keyframes fadeIn {
  from { opacity: 0; transform: translateY(10px); }
  to { opacity: 1; transform: translateY(0); }
}

form {
  animation: fadeIn 0.8s ease forwards;
}

/* Make it responsive */
@media (max-width: 768px) {
  .col-6.offset-3 {
    width: 90%;
    margin: auto;
  }
  h1 {
    font-size: 1.8rem;
  }
}


/* Signup Button and text */
p {
  text-align: center;
  margin-top: 15px;
  color: #555;
  font-size: 0.95rem;
}

.signup-text {
  text-align: center;
  margin-top: 15px;
  color: #555;
  font-size: 0.95rem;
}

.signup-link {
  color: #00bfa5;
  font-weight: 500;
  text-decoration: none;
  transition: color 0.3s ease;
}

.signup-link:hover {
  color: #00d1c1;
  text-decoration: underline;
}
</style>



<div class="row mt-3">
    <h1 class="col-6 offset-3">Login</h1>
    <div class="col-6 offset-3">
        <form action="/login" method="post" class="needs-validation" novalidate>
            <div class="mb-3">
          <label for="username" class="form-label">Username</label>
          <input
           name="username"
           placeholder="Enter your name" 
           id="username"
           type="text"
           autocomplete="off"
            class="form-control"
            required
             />
      
        </div>
       
               <div class="mb-3">
          <label for="password" class="form-label">Password</label>
          <input
           name="password"
           placeholder="Enter your password" 
           id="password"
           type="password"
           autocomplete="off"
            class="form-control"
            required
             />
          </div>
          <button class="btn btn-success">Login</button>
        </form>
    </div>
