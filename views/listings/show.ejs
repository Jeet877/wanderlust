<% var wishlist = typeof wishlist !== 'undefined' ? wishlist : { listings: [] }; %>

<% layout("/layouts/boilerplate") %>

<div class="row mt-3">
  <div class="col-8 offset-3">
<div class="col-12">
  <h3 style="margin-left: 150px;"><i><%= listing.title %></i></h3><br>
</div><br>
  </div>

 <div  class="row flex-row flex-nowrap overflow-auto g-3 mb-3">
  <% 
    // Convert images to array: new listings already have listing.images, 
    // old listings with single image listing.image will be wrapped in an array
    let imagesArray = [];
    if (listing.images && listing.images.length > 0) {
      imagesArray = listing.images;
    } else if (listing.image && listing.image.url) {
      imagesArray = [listing.image];
    }
  %>

  <% if (imagesArray.length > 0) { %>
    <% imagesArray.forEach(img => { %>
      <div class="col-auto">
        <img src="<%= img.url %>" 
             alt="Listing Image" 
             class="card-img-top show-img card-image-bottom" 
             style="width: 250px; height: 180px; object-fit: cover; border-radius: 8px;">
      </div>
    <% }) %>
  <% } else { %>
    <!-- Placeholder if no image -->
    <div class="col-auto">
      <img src="/images/placeholder.jpg" 
           alt="Placeholder Image"
           class="card-img-top show-img card-image-bottom" 
           style="width: 250px; height: 180px; object-fit: cover; border-radius: 8px;">
    </div>
  <% } %>
</div>



    <div class="card-bodyhere"><br><br>
      <p class="card-text"><b>Owned by :--</b> <i><%= listing.owner?listing.owner.username:"Unknown username" %></i></p>
      <p class="card-text"><%= listing.description %></p>
      <p class="card-text">&#8377; <%= listing.price.toLocaleString("en-IN") %></p>
      <p class="card-text">👁️ <%= listing.views %> Views</p>
      <p class="card-text"><%= listing.location %></p>
      <p class="card-text"><%= listing.country %></p>
    </div>
  </div>

  <br />

  <br>

<!-- ❤️ Wishlist Button -->
<form action="/wishlist/<%= listing._id %>" method="POST" class="mt-2">
  <% if (
    wishlist &&
    wishlist.listings &&
    wishlist.listings.some(l => String(l._id) === String(listing._id))
  ) { %>
    <button class="btn btn-danger">💔 Remove from Wishlist</button>
  <% } else { %>
    <button class="btn btn-outline-danger">💖 Add to Wishlist</button>
  <% } %>
</form>

<br> 
<div class="d-flex justify-content-between align-items-center offset-0 mb-3">
  
  <!-- Left Side: Edit + Delete -->
  <div class="d-flex gap-3">
    <a href="/listings/<%= listing._id %>/edit" class="btn btn-dark px-4" style="background-color: #d74040;">Edit</a>

    <form method="POST" action="/listings/<%= listing._id %>?_method=DELETE">
      <button class="btn btn-dark" style="background-color: #d74040;">Delete</button>
    </form>
  </div>

  <!-- Right Side: Reserve -->
  <a 
    href="/listings/<%= listing._id %>/bookings/new"
    class="btn btn-primary w-25 shadow-sm py-2 fw-semibold"
    style="transition: 0.2s ease; border-radius: 10px;">
    Reserve
  </a>
</div>


<!-- 📍 Listing Location Map -->
<div class="container my-4">
  <h4><b>Location</b></h4>
  <div
    id="map"
    style="width: 100%; height: 350px; border-radius: 12px;"
  ></div>
</div>


    <!-- Review Section -->
     <br><br>
    <h4><B>Leave a Review</B></h4>
    <form action="/listings/<%= listing._id %>/reviews" method="post" novalidate class="needs-validation">
      <div class="mb-3 mt-3">
        <!-- <label for="rating" class="form-label">Rating</label> -->
      </div>

      <fieldset class="starability-heartbeat">
        <legend>First rating:</legend>
        <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="0" checked aria-label="No rating." />
        <input type="radio" id="first-rate1" name="review[rating]" value="1" />
        <label for="first-rate1" title="Terrible">1 star</label>
        <input type="radio" id="first-rate2" name="review[rating]" value="2" />
        <label for="first-rate2" title="Not good">2 stars</label>
        <input type="radio" id="first-rate3" name="review[rating]" value="3" />
        <label for="first-rate3" title="Average">3 stars</label>
        <input type="radio" id="first-rate4" name="review[rating]" value="4" />
        <label for="first-rate4" title="Very good">4 stars</label>
        <input type="radio" id="first-rate5" name="review[rating]" value="5" />
        <label for="first-rate5" title="Amazing">5 stars</label>
      </fieldset>

      <div class="mb-3 mt-3">
        <label for="comment" class="form-label">Comments</label>
        <textarea name="review[comment]" id="comment" cols="30" rows="5" class="form-control" required></textarea>
        <div class="invalid-feedback">Please add some comments for review</div>
      </div>
      <button class="btn btn-outline-dark">Submit</button>
    </form>

    <hr />
<p><b>All Reviews</b></p>
<div class="row-3">
  <div class="row flex-row flex-nowrap overflow-auto g-3">
    <% if (listing.reviews && listing.reviews.length > 0) { %>
      <% listing.reviews.forEach(review => { %>
        <div class="card col-5 ms-3 mb-3">
          <div class="card-body">
            <!-- Username -->
            <h5 class="card-title">
              <% if (review.author && review.author.username) { %>
                <%= review.author.username %>
              <% } else { %>
                Anonymous
              <% } %>
            </h5>

            <!-- Comment -->
            <p class="card-text"><%= review.comment %></p>

            <!-- Star symbols instead of number -->
            <p class="card-text">
              <% for (let i = 0; i < review.rating; i++) { %>
                ⭐
              <% } %>
            </p>

            <!-- Delete button -->
            <form class="mb-3" method="POST" action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE">
              <button class="btn btn-sm btn-dark">Delete</button>
            </form>
          </div>
        </div>
      <% }) %>
    <% } else { %>
      <p>No reviews yet.</p>
    <% } %>
  </div>
</div>

  </div>
</div>




<!-- <script src="/public/js/reveal.js"></script> -->





<script>
  const LAT = Number(<%= listing.geometry?.coordinates?.[1] ?? 28.6139 %>);
  const LNG = Number(<%= listing.geometry?.coordinates?.[0] ?? 77.2090 %>);

  document.addEventListener("DOMContentLoaded", () => {
    const map = new maplibregl.Map({
      container: 'map',
      style: {
        version: 8,
        sources: {
          osm: {
            type: 'raster',
            tiles: [
              'https://a.tile.openstreetmap.org/{z}/{x}/{y}.png',
              'https://b.tile.openstreetmap.org/{z}/{x}/{y}.png',
              'https://c.tile.openstreetmap.org/{z}/{x}/{y}.png'
            ],
            tileSize: 256
          }
        },
        layers: [
          {
            id: 'osm',
            type: 'raster',
            source: 'osm'
          }
        ]
      },
      center: [LNG, LAT],
      zoom: 12
    });

    new maplibregl.Marker({ color: 'red' })
      .setLngLat([LNG, LAT])
      .addTo(map);
  });
</script>




















































